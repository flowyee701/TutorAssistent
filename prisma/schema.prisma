// schema.prisma
// Prisma-схема для AI-ассистента репетиторов
// Для использования с PostgreSQL 16 + pgvector

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// =========================================
// Перечисления
// =========================================

enum Subject {
  MATH_PROFILE
  MATH_BASE
  PHYSICS
  INFORMATICS
}

enum ExamType {
  OGE
  EGE
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
  GRACE_PERIOD
}

enum VerificationStatus {
  AUTO_PARSED
  HUMAN_VERIFIED
  COMMUNITY_VERIFIED
  FLAGGED
}

enum HomeworkStatus {
  DRAFT
  GENERATED
  ARCHIVED
}

enum HomeworkFormat {
  WARMUP
  HOMEWORK_BY_TOPIC
  TEST
  EGE_VARIANT
  CUSTOM
}

enum MaterialProcessingStatus {
  UPLOADED
  PARSING
  READY_FOR_REVIEW
  CONFIRMED
  FAILED
}

// =========================================
// Пользователи и подписки
// =========================================

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  email       String   @unique
  name        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  subscription      Subscription?
  students          Student[]
  homeworks         Homework[]
  lessons           Lesson[]
  studentPayments   StudentPayment[]
  ownedTasks        Task[]            @relation("OwnedTasks")
  tutorMaterials    TutorMaterial[]

  @@index([clerkId])
  @@index([email])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 SubscriptionPlan
  status               SubscriptionStatus
  startDate            DateTime           @default(now())
  endDate              DateTime
  yukassaPaymentId     String?
  yukassaPaymentMethod String?            // токен для рекуррентного списания
  cancelledAt          DateTime?

  payments PaymentRecord[]

  @@index([userId])
  @@index([status, endDate])
}

model PaymentRecord {
  id              String       @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id])
  amount          Int          // в копейках
  currency        String       @default("RUB")
  status          String       // succeeded, pending, canceled
  yukassaId       String?      @unique
  createdAt       DateTime     @default(now())
  paidAt          DateTime?

  @@index([subscriptionId])
}

// =========================================
// Ученики
// =========================================

model Student {
  id          String   @id @default(cuid())
  tutorId     String
  tutor       User     @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  name        String
  grade       Int?
  examTarget  ExamType?
  subject     Subject?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  weakTopics StudentWeakTopic[]
  homeworks  Homework[]
  lessons    Lesson[]
  payments   StudentPayment[]

  @@index([tutorId])
}

model StudentWeakTopic {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tagId     String
  tag       TaskTag  @relation(fields: [tagId], references: [id])
  severity  Int      @default(2)  // 1-3, насколько слабое место
  notes     String?
  createdAt DateTime @default(now())

  @@unique([studentId, tagId])
  @@index([studentId])
}

// =========================================
// Дерево тегов (темы)
// =========================================

model TaskTag {
  id          String     @id @default(cuid())
  code        String     @unique           // напр. "math_profile_ege.algebra.equations.quadratic"
  path        String     @unique           // материализованный путь, тот же что code
  name        String                       // отображаемое имя: "Квадратные уравнения"
  description String?
  subject     Subject
  examType    ExamType
  parentId    String?
  parent      TaskTag?   @relation("TagHierarchy", fields: [parentId], references: [id])
  children    TaskTag[]  @relation("TagHierarchy")
  depth       Int        @default(0)
  sortOrder   Int        @default(0)

  taskLinks       TaskTagLink[]
  studentWeakTopics StudentWeakTopic[]
  lessonTopics    LessonTopic[]

  @@index([subject, examType])
  @@index([parentId])
  @@index([path])
}

// =========================================
// Задачи
// =========================================

model Task {
  id                String              @id @default(cuid())
  subject           Subject
  examType          ExamType
  taskNumber        Int?                // напр. 13 для №13 ЕГЭ
  difficulty        Int                 @default(3) // 1-5
  source            String              // FIPI_2024_DEMO, USER_UPLOAD, ...
  sourceMetadata    Json?               // { pdfFile, page, region }

  statementLatex    String              // условие с LaTeX-формулами
  statementText     String              // plain-версия для full-text search
  imageUrls         String[]            // S3-ссылки на картинки
  answer            String?
  solutionLatex     String?
  solutionText      String?

  ownerId           String?             // NULL для общего банка
  owner             User?               @relation("OwnedTasks", fields: [ownerId], references: [id])

  verificationStatus VerificationStatus @default(AUTO_PARSED)
  contentHash        String             @unique  // SHA-256 от statementText для дедупликации
  flagCount          Int                @default(0)

  embedding          Unsupported("vector(1536)")?  // pgvector, заполняется отложенно

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  tagLinks       TaskTagLink[]
  homeworkTasks  HomeworkTask[]

  @@index([subject, examType])
  @@index([verificationStatus])
  @@index([ownerId])
  @@index([difficulty])
  @@index([taskNumber])
}

model TaskTagLink {
  id     String  @id @default(cuid())
  taskId String
  task   Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  String
  tag    TaskTag @relation(fields: [tagId], references: [id])

  @@unique([taskId, tagId])
  @@index([tagId])
  @@index([taskId])
}

// =========================================
// Домашние задания
// =========================================

model Homework {
  id              String         @id @default(cuid())
  tutorId         String
  tutor           User           @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  studentId       String?
  student         Student?       @relation(fields: [studentId], references: [id])

  title           String
  format          HomeworkFormat @default(HOMEWORK_BY_TOPIC)
  status          HomeworkStatus @default(DRAFT)

  pdfUrl          String?
  pdfWithAnswersUrl String?
  pdfGeneratedAt  DateTime?

  notes           String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  tasks           HomeworkTask[]

  @@index([tutorId])
  @@index([studentId])
}

model HomeworkTask {
  id          String   @id @default(cuid())
  homeworkId  String
  homework    Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
  order       Int

  @@unique([homeworkId, taskId])
  @@unique([homeworkId, order])
  @@index([homeworkId])
}

// =========================================
// Ведомости занятий
// =========================================

model Lesson {
  id          String   @id @default(cuid())
  tutorId     String
  tutor       User     @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date        DateTime
  duration    Int?     // минуты
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  topics      LessonTopic[]

  @@index([tutorId, date])
  @@index([studentId, date])
}

model LessonTopic {
  id        String   @id @default(cuid())
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  tagId     String
  tag       TaskTag  @relation(fields: [tagId], references: [id])
  needsReview Boolean @default(false)  // отметить «надо повторить»
  notes     String?

  @@unique([lessonId, tagId])
}

// =========================================
// Учёт оплат ученика репетитору (не подписка!)
// =========================================

model StudentPayment {
  id            String   @id @default(cuid())
  tutorId       String
  tutor         User     @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount        Int      // в копейках
  lessonsCount  Int      // на сколько занятий оплата
  paymentDate   DateTime @default(now())
  notes         String?

  createdAt     DateTime @default(now())

  @@index([tutorId])
  @@index([studentId])
}

// =========================================
// Загруженные методички
// =========================================

model TutorMaterial {
  id                  String                   @id @default(cuid())
  tutorId             String
  tutor               User                     @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  originalFilename    String
  s3Key               String
  fileSize            Int
  pageCount           Int?
  processingStatus    MaterialProcessingStatus @default(UPLOADED)
  extractedTasksCount Int                      @default(0)
  confirmedTasksCount Int                      @default(0)
  processingError     String?

  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([tutorId])
}
